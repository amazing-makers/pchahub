# ============================================================
# pchahub 환경변수
# ============================================================

# NextAuth 시크릿 (9개 사이트가 공유 — SSO 패스포트 서명에 사용)
NEXTAUTH_SECRET=your-shared-secret-here-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# 공정거래위원회 가맹사업정보제공시스템 API 키
# https://www.data.go.kr 에서 아래 5개 API 각각 활용신청 (프로젝트 서비스키)
#
#   1. 공정거래위원회_가맹정보_브랜드 목록 정보 제공 서비스
#   2. 공정거래위원회_페어데이터_브랜드별 가맹점/직영점 집계 및 평균매출
#   3. 공정거래위원회_가맹정보_가맹본부 일반 정보 상세 제공
#   4. 공정거래위원회_가맹정보_가맹본부 등록 목록 정보 제공
#   5. 공정거래위원회_가맹정보_정보공개서 목록/목차/본문 조회 (1세트)
#
# 발급된 키는 5개 모두 동일하며 KFTC_API_KEY 하나에 저장하면 된다.
# 미설정 시 mock-data.ts 폴백으로 동작한다 (개발용).
# ============================================================
# KFTC_API_KEY=

# ============================================================
# (선택) Supabase 연결
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
