# ============================================================
# pchahub 환경변수
# ============================================================

# NextAuth 시크릿 (9개 사이트가 공유 — SSO 패스포트 서명에 사용)
NEXTAUTH_SECRET=your-shared-secret-here-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# pchahub 핵심 차별점: 공정위 5개 가맹 API를 통합한 "모든 가맹 정보 한 화면"
# ============================================================
# https://www.data.go.kr 에서 아래 5개 API 각각 활용신청.
#
# 키 종류: "개인 서비스키" / "프로젝트 서비스키" 둘 다 가능.
# 공정위 가맹 API는 대부분 개인 서비스키만 발급되며, 호출 동작은 동일.
# 마이페이지에서 발급되는 "Decoding 키"를 그대로 사용한다.
#
# 신청 권장 순서 (가장 깔끔한 데이터부터):
#   1. 공정거래위원회_페어데이터_브랜드별 가맹점/직영점 집계 + 평균매출
#      → 매장 수·연차별 변화·평균 매출 (정제된 학습데이터)
#   2. 공정거래위원회_가맹정보_브랜드 목록 정보 제공 서비스
#      → 모든 가맹 브랜드 디렉토리 (검색·필터링)
#   3. 공정거래위원회_가맹정보_가맹본부 일반 정보 상세 제공
#      → 회사명·대표·기업규모·주소
#   4. 공정거래위원회_가맹정보_가맹본부 등록 목록 정보 제공
#      → 사업자등록번호·법인등록번호 (재무 분석)
#   5. 공정거래위원회_가맹정보_정보공개서 목록/목차/본문 조회 (1세트)
#      → 가맹비·보증금·인테리어비·계약조건 원본 (XML)
#
# 발급된 키는 5개 모두 동일한 본인 계정의 마스터 키 하나.
# KFTC_API_KEY 한 곳에 저장하면 모든 API 호출 가능.
# 미설정 시 mock-data.ts 폴백으로 동작한다 (개발용).
# ============================================================
# KFTC_API_KEY=

# ============================================================
# (선택) Supabase 연결
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
