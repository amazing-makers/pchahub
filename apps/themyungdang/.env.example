# ============================================================
# themyungdang 환경변수
# ============================================================

# NextAuth 시크릿 (9개 사이트가 공유 — SSO 패스포트 서명에 사용)
NEXTAUTH_SECRET=your-shared-secret-here-32-chars-min
NEXTAUTH_URL=http://localhost:3003

# ============================================================
# 외부 데이터 소스 API 키
# ============================================================
# themyungdang은 3개 외부 데이터 소스를 통합:
#   1. 공공데이터포털 (data.go.kr) — 국토부 실거래가, 소상공인 상권정보
#   2. 한국부동산원 (REB) — 부동산 통계 (별도 발급)
#
# 키를 1개씩 별도로 받는 게 원칙이지만, 같은 사용자 계정이면 같은 키로
# 여러 API 호출 가능. 환경변수 1개로 시작 가능.
# ============================================================

# 공공데이터포털 통합 키 (소상공인진흥공단_상권정보, 국토부_실거래가 등)
# DATAGO_API_KEY=

# 한국부동산원 별도 키 (https://www.reb.or.kr/r-one/openapi 에서 신청)
# REB_API_KEY=

# ============================================================
# 활용신청한 외부 API 리스트 (registry.ts 참고)
# ============================================================
#  1. 한국부동산원_부동산통계 (REB)              → 임대료·매매가 통계
#  2. 국토교통부_상업업무용부동산_실거래가         → 매물 시세 검증
#  3. 소상공인시장진흥공단_상권정보               → 유동인구·업종 분포
#  4. 소상공인시장진흥공단_상가(상권)정보         → 상가 디렉토리
# ============================================================
