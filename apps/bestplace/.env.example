# ============================================================
# bestplace 환경변수
# ============================================================

NEXTAUTH_SECRET=your-shared-secret-here-32-chars-min
NEXTAUTH_URL=http://localhost:3006

# ============================================================
# 외부 데이터 소스 API 키
# ============================================================
# bestplace은 4개 외부 데이터 소스를 통합:
#   1. 소상공인시장진흥공단_상가(상권)정보 → 매장 1차 디렉토리
#   2. 소상공인시장진흥공단_상권정보       → 상권 영역
#   3. 통계청 KOSIS                       → 지역 인구·통계
#   4. 국세청_사업자등록 진위확인          → 매장 검증

# KFTC_API_KEY=      # DATAGO_API_KEY 미설정 시 fallback
# DATAGO_API_KEY=
# REB_API_KEY=       # reb.or.kr 한국부동산원 (별도 발급)
# NTS_API_KEY=       # api.odcloud.kr 국세청 사업자등록 진위 (별도 발급)
