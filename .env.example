# ==========================================
# amakers Platform — Environment Variables
# .env.example → .env 복사 후 실제 값 입력
# ==========================================

# ---------- Database (Supabase + Prisma) ----------
# Supabase 프로젝트 설정 > Database > Connection string
#
# Transaction mode (pooler) — Vercel 서버리스에서 사용
DATABASE_URL="postgresql://postgres.[YOUR-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Direct connection — prisma migrate / db push 에서 사용
DIRECT_URL="postgresql://postgres.[YOUR-REF]:[PASSWORD]@aws-0-ap-northeast-2.supabase.com:5432/postgres"

# ---------- NextAuth (9개 앱이 SSO로 공유) ----------
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=""
# 로컬 개발 시 앱마다 다른 포트 사용
# 배포 시 아래 NEXT_PUBLIC_*_URL 중 해당 앱 URL 사용
NEXTAUTH_URL="http://localhost:3000"

# ---------- OAuth 프로바이더 ----------
# 카카오: https://developers.kakao.com
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# 네이버: https://developers.naver.com
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 구글: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- 카카오 지도 (themyungdang, bestplace) ----------
NEXT_PUBLIC_KAKAO_MAP_KEY=""

# ---------- 토스 페이먼츠 ----------
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# ---------- Cloudflare R2 (이미지 스토리지) ----------
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="amakers"
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_PUBLIC_URL=""

# ---------- Analytics ----------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# ---------- 에러 추적 ----------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---------- 이메일 (Resend) ----------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@amakers.co.kr"

# ---------- 앱 URL (프로덕션) ----------
NEXT_PUBLIC_PCHAHUB_URL="https://pchahub.amakers.co.kr"
NEXT_PUBLIC_OPENRUN_URL="https://openrun.amakers.co.kr"
NEXT_PUBLIC_GONGGANHANSU_URL="https://gongganhansu.amakers.co.kr"
NEXT_PUBLIC_THEMYUNGDANG_URL="https://themyungdang.amakers.co.kr"
NEXT_PUBLIC_THEMANUAL_URL="https://themanual.amakers.co.kr"
NEXT_PUBLIC_JANGSANOTE_URL="https://jangsanote.amakers.co.kr"
NEXT_PUBLIC_BESTPLACE_URL="https://bestplace.amakers.co.kr"
NEXT_PUBLIC_CHANGUPDOCU_URL="https://changupdocu.amakers.co.kr"
NEXT_PUBLIC_PCHABRIDGE_URL="https://pchabridge.amakers.co.kr"

# ---------- 공공데이터포털 (data.go.kr) ----------
# 발급: https://www.data.go.kr
KFTC_API_KEY=""      # 공정거래위원회 가맹정보 API
DATAGO_API_KEY=""    # 국토부·KOSIS·소상공인 상권 API
REB_API_KEY=""       # 한국부동산원 (reb.or.kr)
NTS_API_KEY=""       # 국세청 사업자등록 진위 (odcloud.kr)

# ---------- Vercel Cron 보안 ----------
# Vercel → 프로젝트 Settings → Environment Variables 에서도 동일하게 설정
# 아무 랜덤 문자열 (예: openssl rand -hex 32)
CRON_SECRET=""
