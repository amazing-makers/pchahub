# ==========================================
# amakers Platform — Environment Variables
# Copy to .env and fill in real values
# ==========================================

# ---------- Database (Supabase PostgreSQL) ----------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ---------- NextAuth (Shared across all 9 apps for SSO) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ---------- OAuth Providers ----------
# Kakao: https://developers.kakao.com
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Naver: https://developers.naver.com
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Google: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Kakao Map (themyungdang, bestplace) ----------
NEXT_PUBLIC_KAKAO_MAP_KEY=""

# ---------- Toss Payments ----------
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# ---------- Cloudflare R2 (Image hosting) ----------
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="amakers"
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_PUBLIC_URL=""

# ---------- Analytics ----------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# ---------- Error Tracking ----------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---------- Email (Resend) ----------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@amakers.io"

# ---------- App URLs (production) ----------
NEXT_PUBLIC_PCHAHUB_URL="https://pchahub.kr"
NEXT_PUBLIC_OPENRUN_URL="https://openrun.kr"
NEXT_PUBLIC_GONGGANHANSU_URL="https://gongganhansu.kr"
NEXT_PUBLIC_THEMYUNGDANG_URL="https://themyungdang.kr"
NEXT_PUBLIC_THEMANUAL_URL="https://themanual.kr"
NEXT_PUBLIC_JANGSANOTE_URL="https://jangsanote.kr"
NEXT_PUBLIC_BESTPLACE_URL="https://bestplace.kr"
NEXT_PUBLIC_CHANGUPDOCU_URL="https://changupdocu.kr"
NEXT_PUBLIC_PCHABRIDGE_URL="https://pchabridge.kr"
